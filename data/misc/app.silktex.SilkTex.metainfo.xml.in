<component type="desktop-application">
  <id>app.silktex.SilkTex</id>

  <name>SilkTex</name>
  <summary>Modern LaTeX editor for GNOME</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <description>
    <p>
      SilkTex is a modern LaTeX editor built with GTK4 and libadwaita.
      It provides an integrated live PDF preview, a document outline,
      snippet shortcuts, and a clean preferences dialog — a modernised
      take on the classic Gummi editor.
    </p>
    <p>Features include:</p>
    <ul>
      <li>Live PDF preview with high-DPI aware rendering</li>
      <li>Document outline with jump-to-section</li>
      <li>Configurable snippet shortcuts with tab-stops</li>
      <li>SyncTeX support for forward / inverse sync</li>
      <li>BibTeX, makeindex, and cleanup integrations</li>
    </ul>
  </description>

  <launchable type="desktop-id">app.silktex.SilkTex.desktop</launchable>

  <url type="homepage">https://github.com/DERK0CHER/SilkTex</url>
  <url type="bugtracker">https://github.com/DERK0CHER/SilkTex/issues</url>
  <url type="vcs-browser">https://github.com/DERK0CHER/SilkTex</url>

  <developer id="app.silktex">
    <name>Bela Georg Barthelmes</name>
  </developer>

  <content_rating type="oars-1.1" />

  <categories>
    <category>Office</category>
    <category>Publishing</category>
    <category>WordProcessor</category>
  </categories>

  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>

  <requires>
    <display_length compare="ge">768</display_length>
  </requires>

  <!--
    Flathub requires at least one screenshot. Before submitting, upload
    PNGs (recommended 1280x720 or similar 16:9) to a durable location —
    e.g. an assets/ branch in this repo, or a release asset — and point
    the URLs below at them. Remove this comment when done.
  -->
  <screenshots>
    <screenshot type="default">
      <caption>Editor with live PDF preview</caption>
      <image>https://raw.githubusercontent.com/DERK0CHER/SilkTex/assets/screenshots/editor.png</image>
    </screenshot>
    <screenshot>
      <caption>Document outline and snippet editor</caption>
      <image>https://raw.githubusercontent.com/DERK0CHER/SilkTex/assets/screenshots/outline.png</image>
    </screenshot>
  </screenshots>

  <releases>
    <release version="1.0.2" date="2026-04-26">
      <description>
        <p>Maintenance release.</p>
        <ul>
          <li>Flatpak targets GNOME 50; manifest and docs aligned with the runtime.</li>
        </ul>
      </description>
    </release>
    <release version="0.9.1" date="2026-04-24">
      <description>
        <p>First Flathub-ready release.</p>
        <ul>
          <li>Polished libadwaita preferences (snippet shortcut preview
              now uses an entry-row suffix label instead of an invalid
              subtitle cast).</li>
          <li>AdwTabBar autohide on single-tab windows.</li>
          <li>Updated AppStream metainfo with project URLs and screenshots.</li>
        </ul>
      </description>
    </release>
    <release version="0.9.0" date="2026-04-24">
      <description>
        <p>Initial SilkTex release based on the Gummi code base.</p>
        <ul>
          <li>Ported the UI to GTK 4 / libadwaita / Blueprint.</li>
          <li>HiDPI-aware PDF preview with device-scale aware rendering.</li>
          <li>Configurable snippet engine with two global modifier keys
              plus a letter, and $1 / $2 / $0 tab placeholders.</li>
          <li>Flatpak manifest and Nix dev shell.</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
